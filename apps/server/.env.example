# HTTP port for the Cavos proxy server (default: 4000)
PORT=4000

# Cavos App ID from the Cavos dashboard (required)
CAVOS_APP_ID=your-cavos-app-id

# App salt used for deterministic wallet derivation (default: geko-mobile)
CAVOS_APP_SALT=geko-mobile

# Stellar network: testnet | mainnet (default: testnet)
CAVOS_NETWORK=testnet
