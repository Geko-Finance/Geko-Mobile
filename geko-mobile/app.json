{
  "expo": {
    "name": "geko-mobile",
    "slug": "geko-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/features/shared/assets/icons/iconApp.png",
    "scheme": "gekomobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gekomobile.gekomobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./src/features/shared/assets/icons/iconApp.png",
        "backgroundImage": "./src/features/shared/assets/icons/iconApp.png",
        "monochromeImage": "./src/features/shared/assets/icons/iconApp.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.gekomobile.gekomobile"
    },
    "web": {
      "output": "static",
      "favicon": "./src/features/shared/assets/icons/iconApp.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/features/shared/assets/images/splash/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ce6acf82-0902-40c8-b1ef-542195c6d92e"
      }
    },
    "owner": "geko-mobile"
  }
}
