# PostgreSQL connection string (local docker-compose default shown)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geko

# HTTP port for the Geko backend API (default: 4000)
PORT=4000

# JWT signing secrets (generate strong random values for non-local use)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# JWT token lifetimes (used in a later auth phase)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Mobile app origin/scheme for CORS (Expo dev server example)
MOBILE_APP_ORIGIN=http://localhost:8081

# Cavos App ID from the Cavos dashboard (required)
CAVOS_APP_ID=your-cavos-app-id

# App salt used for deterministic wallet derivation (default: geko-mobile)
CAVOS_APP_SALT=geko-mobile

# Stellar network: testnet | mainnet (default: testnet)
CAVOS_NETWORK=testnet

# AES-256-GCM key for wallet secrets (base64-encoded 32 bytes). Generate with:
#   openssl rand -base64 32
WALLET_SECRETS_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-base64-32
